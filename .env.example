# ─── eShop ────────────────────────────────────────────────────────────────────
ESHOPBOX_EMAIL=isha@nubokind.com
ESHOPBOX_BASE_URL=https://auth.myeshopbox.com/auth/login
ESHOPBOX_INVOICE_URL=https://billing.myeshopbox.com/portal/eshopbox/index#/invoices?filter_by=Status.Invoices
DOWNLOAD_PATH=./src/storage/downloaded

# ─── Gmail IMAP (primary OTP method) ────────────────────────────────────────
# Your Gmail address (must have IMAP enabled in Gmail Settings)
EMAIL_USER=isha@nubokind.com

# App Password: https://myaccount.google.com/apppasswords
# (NOT your regular Gmail password — requires 2FA to be enabled)
EMAIL_APP_PASSWORD=bxejisrkdkjhsbdy

# IMAP settings — defaults work for Gmail
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Filter OTP emails by sender (partial match, case-insensitive)
IMAP_FROM_FILTER=eshopbox

# How far back to look for OTP emails (minutes)
IMAP_SINCE_MINUTES=15

# Retry settings
IMAP_MAX_ATTEMPTS=5
IMAP_POLL_INTERVAL_MS=5000

# ─── Dashboard ────────────────────────────────────────────────────────────────
UI_PORT=3030

# ─── Automation options ───────────────────────────────────────────────────────
# Run browser in headless mode (true for production, false for debugging)
ESHOPBOX_HEADLESS=true

# Path to save browser session state (avoids re-login on next run)
ESHOPBOX_SESSION_PATH=eshopbox-session.json

# Skip invoice download (useful for testing auth-only flow)
ESHOPBOX_SKIP_DOWNLOAD=false

# ─── Dev overrides ────────────────────────────────────────────────────────────
# Hardcode an OTP for testing (skips IMAP fetch entirely)
# ESHOPBOX_DEV_OTP=123456

# Allow manual OTP entry at terminal prompt (fallback)
ESHOPBOX_MANUAL_OTP=false
